<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>月度工作报表 · 病理科</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app" style="max-width:980px;">
  <nav class="nav">
    <div class="nav-brand">
      <div class="nav-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
      </div>
      <span>月度工作报表</span>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link">运营分析首页</a>
      <a href="/workload/template" class="nav-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        下载工作报表模板
      </a>
    </div>
  </nav>

  <main class="main">
    <% if (!workloadAnalysis) { %>
    <section class="hero" style="margin-bottom:28px;">
      <div class="hero-content">
        <h1 style="font-size:28px;">工作量 / 收入 / 会诊<br>柱状图可视化</h1>
        <p class="hero-sub">使用专用 Excel（工作量统计、收入金额、会诊统计三个 Sheet），上传后自动生成对比柱状图；可导出 HTML，单图支持 PNG 下载。</p>
      </div>
    </section>
    <% } %>

    <section class="upload-section">
      <% if (error) { %>
        <div class="alert alert-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <%= error %>
        </div>
      <% } %>

      <form action="/workload/upload" method="POST" enctype="multipart/form-data" class="upload-form" id="uploadFormWorkload">
        <div class="upload-zone" id="uploadZoneWl">
          <div class="upload-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <p class="upload-text">拖拽「月度工作报表」Excel 到此处</p>
          <p class="upload-hint">或点击选择 &middot; .xlsx / .xls &middot; 最大 20MB</p>
          <input type="file" name="datafile" accept=".xlsx,.xls" id="fileInputWl" required>
        </div>
        <div class="file-info" id="fileInfoWl">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span id="fileNameWl"></span>
          <button type="button" class="file-clear" id="fileClearWl">&times;</button>
        </div>
        <button type="submit" class="btn btn-primary btn-lg" id="btnSubmitWl" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span>生成图表</span>
        </button>
      </form>
    </section>

    <% if (workloadAnalysis && workloadReportBody) { %>
    <style>.app { max-width: 1140px !important; transition: max-width 0.35s ease; }</style>
    <section class="result-actions" style="margin: 28px 0 20px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="/workload/preview" target="_blank" class="btn btn-primary btn-lg" style="padding: 14px 28px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        独立页预览
      </a>
      <a href="/workload/export" class="btn btn-success btn-lg" download style="padding: 14px 28px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        下载 HTML
      </a>
      <button type="button" id="btnPdfWl" class="btn btn-lg" style="padding: 14px 28px; background: #7c3a2d; color: #fff; border: none; cursor: pointer;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        导出 PDF
      </button>
    </section>
    <p style="text-align:center;font-size:13px;color:var(--text-3);margin-bottom:12px;">每张图下方可点击「下载该图为 PNG」（需图表渲染完成后再点）。</p>
    <div class="embedded-report-container" style="background: #f8fafc; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); border: 1px solid #e2e8f0; margin-bottom: 40px; overflow: hidden;">
      <%- workloadReportBody %>
    </div>
    <% } %>
  </main>

  <footer class="app-footer">
    <p>病理科月度工作报表 · ECharts</p>
  </footer>
</div>
<div id="pdfToastWl" style="display:none;position:fixed;bottom:32px;left:50%;transform:translateX(-50%);background:rgba(30,30,30,0.92);color:#fff;padding:12px 24px;border-radius:10px;font-size:14px;z-index:9999;"></div>

<script>
(function(){
  var zone = document.getElementById('uploadZoneWl');
  var input = document.getElementById('fileInputWl');
  var info = document.getElementById('fileInfoWl');
  var nameEl = document.getElementById('fileNameWl');
  var btn = document.getElementById('btnSubmitWl');
  var clear = document.getElementById('fileClearWl');
  if(!zone)return;
  zone.addEventListener('click', function(e){ if(e.target !== input) input.click(); });
  zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.classList.add('dragover'); });
  zone.addEventListener('dragleave', function(){ zone.classList.remove('dragover'); });
  zone.addEventListener('drop', function(e){
    e.preventDefault(); zone.classList.remove('dragover');
    if (e.dataTransfer.files.length) {
      input.files = e.dataTransfer.files;
      onFile();
    }
  });
  input.addEventListener('change', onFile);
  clear.addEventListener('click', function(){
    input.value = '';
    info.classList.remove('show');
    zone.style.display = '';
    btn.disabled = true;
  });
  function onFile(){
    if (!input.files.length) return;
    var f = input.files[0];
    nameEl.textContent = f.name + ' (' + (f.size / 1024).toFixed(0) + ' KB)';
    info.classList.add('show');
    zone.style.display = 'none';
    btn.disabled = false;
  }
  document.getElementById('uploadFormWorkload')?.addEventListener('submit', function(){
    if(btn.dataset.submitting === '1') return;
    btn.dataset.submitting = '1';
    btn.querySelector('span').textContent = '解析中…';
    btn.style.pointerEvents = 'none';
    btn.style.opacity = '0.75';
  });

  document.body.addEventListener('click', function(e){
    var t = e.target.closest('.wl-dl-chart');
    if (!t) return;
    if (typeof echarts === 'undefined') { alert('图表库尚未加载'); return; }
    var id = t.getAttribute('data-chart');
    var dom = document.getElementById(id);
    if (!dom) return;
    var inst = echarts.getInstanceByDom(dom);
    if (!inst) {
      alert('请稍候，图表尚在初始化');
      return;
    }
    var url = inst.getDataURL({ type: 'png', pixelRatio: 2, backgroundColor: '#fff' });
    var a = document.createElement('a');
    a.href = url;
    a.download = id + '.png';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
  });

  function showWlToast(msg, duration){
    var t = document.getElementById('pdfToastWl');
    if(!t)return;
    t.textContent = msg;
    t.style.display = 'block';
    if(duration) setTimeout(function(){ t.style.display = 'none'; }, duration);
  }
  var pdfBtn = document.getElementById('btnPdfWl');
  if(pdfBtn){
    pdfBtn.addEventListener('click', function(){
      pdfBtn.disabled = true;
      pdfBtn.style.opacity = '0.6';
      showWlToast('⏳ PDF 生成中，请稍候…');
      fetch('/workload/pdf')
        .then(function(res){
          if(!res.ok) return res.text().then(function(x){ throw new Error(x); });
          var disp = res.headers.get('Content-Disposition') || '';
          var match = disp.match(/filename\*?=(?:UTF-8'')?([^;]+)/);
          var filename = match ? decodeURIComponent(match[1].replace(/"/g,'')) : '工作报表.pdf';
          return res.blob().then(function(blob){ return { blob: blob, filename: filename }; });
        })
        .then(function(r){
          var url = URL.createObjectURL(r.blob);
          var a = document.createElement('a');
          a.href = url;
          a.download = r.filename;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(function(){ URL.revokeObjectURL(url); }, 800);
          showWlToast('✅ PDF 已下载', 2800);
        })
        .catch(function(err){ showWlToast('❌ 导出失败：' + err.message, 4000); })
        .finally(function(){
          pdfBtn.disabled = false;
          pdfBtn.style.opacity = '';
        });
    });
  }
})();
</script>
</body>
</html>
