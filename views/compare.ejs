<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>多月对比分析 · 病理科</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<style>
.cmp-files-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 14px;
}
.cmp-file-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  background: #f1f5f9;
  border-radius: 8px;
  font-size: 14px;
}
.cmp-file-row .cmp-file-name { flex: 1; color: #0f172a; word-break: break-all; }
.cmp-file-row .cmp-file-size { color: #64748b; font-size: 12px; }
.cmp-file-row .cmp-file-x {
  background: none; border: none; cursor: pointer;
  color: #94a3b8; font-size: 18px; padding: 0 4px;
}
.cmp-file-row .cmp-file-x:hover { color: #dc2626; }
.cmp-files-summary {
  margin-top: 10px;
  font-size: 13px;
  color: #475569;
}
.cmp-files-summary strong { color: #0f172a; }
</style>
</head>
<body>
<div class="app" style="max-width:980px;">
  <nav class="nav">
    <div class="nav-brand">
      <div class="nav-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
      </div>
      <span>多月对比分析</span>
    </div>
    <div class="nav-links">
      <a href="/" class="nav-link">平台首页</a>
      <a href="/ops" class="nav-link">科室运营</a>
      <a href="/workload" class="nav-link">工作报表</a>
      <a href="/workload/template" class="nav-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        下载工作量模板
      </a>
    </div>
  </nav>

  <main class="main">
    <% if (!compareData) { %>
    <section class="hero" style="margin-bottom:28px;">
      <div class="hero-content">
        <h1 style="font-size:28px;">多月工作量对比</h1>
        <p class="hero-sub">上传 2~24 个月度工作量 Excel（与"月度工作报表"格式一致），自动按月份排序，生成 6 张迷你趋势图 + 5 张大对比图，让月份间变化一目了然。</p>
      </div>
    </section>
    <% } %>

    <section class="upload-section">
      <% if (error) { %>
        <div class="alert alert-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <%= error %>
        </div>
      <% } %>

      <form action="/compare/upload" method="POST" enctype="multipart/form-data" class="upload-form" id="cmpUploadForm">
        <div class="upload-zone" id="cmpUploadZone">
          <div class="upload-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <p class="upload-text">拖拽多个月度 Excel 到此处</p>
          <p class="upload-hint">或点击选择 &middot; 支持多选 &middot; .xlsx / .xls &middot; 单个最大 20MB</p>
          <input type="file" name="datafiles" accept=".xlsx,.xls" id="cmpFileInput" multiple>
        </div>

        <div class="cmp-files-list" id="cmpFilesList"></div>
        <div class="cmp-files-summary" id="cmpFilesSummary" style="display:none;"></div>

        <button type="submit" class="btn btn-primary btn-lg" id="cmpBtnSubmit" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span>生成对比报告</span>
        </button>
      </form>
    </section>

    <% if (compareData && compareReportBody) { %>
    <style>.app { max-width: 1320px !important; transition: max-width 0.35s ease; }</style>
    <section class="result-actions" style="margin: 28px 0 20px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="/compare/preview" target="_blank" class="btn btn-primary btn-lg" style="padding: 14px 28px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        独立页预览
      </a>
      <a href="/compare/export" class="btn btn-success btn-lg" download style="padding: 14px 28px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        下载 HTML
      </a>
    </section>
    <div class="embedded-report-container" style="background: #f8fafc; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); border: 1px solid #e2e8f0; margin-bottom: 40px; overflow: hidden;">
      <%- compareReportBody %>
    </div>
    <% } %>
  </main>

  <footer class="app-footer">
    <p>病理数据平台 · 多月对比分析 · ECharts</p>
  </footer>
</div>

<script>
(function(){
  var zone = document.getElementById('cmpUploadZone');
  var input = document.getElementById('cmpFileInput');
  var listEl = document.getElementById('cmpFilesList');
  var summaryEl = document.getElementById('cmpFilesSummary');
  var btn = document.getElementById('cmpBtnSubmit');
  if (!zone) return;

  // 累积已选文件（多次选择会合并）
  var selectedFiles = [];

  zone.addEventListener('click', function(e){ if(e.target !== input) input.click(); });
  zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.classList.add('dragover'); });
  zone.addEventListener('dragleave', function(){ zone.classList.remove('dragover'); });
  zone.addEventListener('drop', function(e){
    e.preventDefault(); zone.classList.remove('dragover');
    if (e.dataTransfer.files.length) addFiles(e.dataTransfer.files);
  });
  input.addEventListener('change', function(){
    if (input.files.length) addFiles(input.files);
    input.value = '';
  });

  function addFiles(files) {
    for (var i = 0; i < files.length; i++) {
      var f = files[i];
      var ext = f.name.toLowerCase().replace(/.*\./, '');
      if (ext !== 'xlsx' && ext !== 'xls') continue;
      // 去重（按 name + size）
      var dup = selectedFiles.some(function(x){ return x.name === f.name && x.size === f.size; });
      if (!dup) selectedFiles.push(f);
    }
    syncInput();
    render();
  }

  function removeAt(idx) {
    selectedFiles.splice(idx, 1);
    syncInput();
    render();
  }

  function syncInput(){
    var dt = new DataTransfer();
    selectedFiles.forEach(function(f){ dt.items.add(f); });
    input.files = dt.files;
  }

  function render(){
    listEl.innerHTML = '';
    selectedFiles.forEach(function(f, idx){
      var row = document.createElement('div');
      row.className = 'cmp-file-row';
      row.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>'
        + '<span class="cmp-file-name">' + escapeHtml(f.name) + '</span>'
        + '<span class="cmp-file-size">' + (f.size / 1024).toFixed(0) + ' KB</span>'
        + '<button type="button" class="cmp-file-x" data-idx="' + idx + '" title="移除">&times;</button>';
      row.querySelector('.cmp-file-x').addEventListener('click', function(){ removeAt(idx); });
      listEl.appendChild(row);
    });
    if (selectedFiles.length) {
      summaryEl.style.display = 'block';
      summaryEl.innerHTML = '已选 <strong>' + selectedFiles.length + '</strong> 个文件'
        + (selectedFiles.length < 2 ? '（至少需要 2 个才能做对比）' : '，提交后将按表格首行的"YYYY年M月"自动排序');
      zone.style.display = 'none';
    } else {
      summaryEl.style.display = 'none';
      zone.style.display = '';
    }
    btn.disabled = selectedFiles.length < 2;
  }

  function escapeHtml(s){
    return String(s).replace(/[&<>"']/g, function(c){
      return { '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[c];
    });
  }

  document.getElementById('cmpUploadForm')?.addEventListener('submit', function(){
    if(btn.dataset.submitting === '1') return;
    btn.dataset.submitting = '1';
    btn.querySelector('span').textContent = '解析中…';
    btn.style.pointerEvents = 'none';
    btn.style.opacity = '0.75';
  });
})();
</script>
</body>
</html>
