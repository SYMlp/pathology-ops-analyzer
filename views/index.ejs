<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>科室运营分析平台</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/css/style.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.2/html2pdf.bundle.min.js" defer></script>
</head>
<body>
<div class="app">
  <nav class="nav">
    <div class="nav-brand">
      <div class="nav-logo">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 002 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0022 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
      </div>
      <span>科室运营分析</span>
    </div>
    <div class="nav-links">
      <a href="/template" class="nav-link">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        下载模板
      </a>
    </div>
  </nav>

  <main class="main">
    <% if (!analysis) { %>
    <section class="hero">
      <div class="hero-content">
        <h1>科室月度运营<br>数据分析平台</h1>
        <p class="hero-sub">上传 Excel 运营数据，秒级生成专业分析报告。涵盖经济运行、效率指标、工作量、全院排名、耗材采购五大维度。</p>
      </div>
      <div class="hero-visual">
        <div class="hero-card hc-1"><span>支收比</span><strong>69.4%</strong></div>
        <div class="hero-card hc-2"><span>门诊量</span><strong>+12.3%</strong></div>
        <div class="hero-card hc-3"><span>满意度</span><strong>#3</strong></div>
      </div>
    </section>
    <% } %>

    <section class="upload-section">
      <% if (error) { %>
        <div class="alert alert-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
          <%= error %>
        </div>
      <% } %>

      <form action="/upload" method="POST" enctype="multipart/form-data" class="upload-form" id="uploadForm">
        <div class="upload-zone" id="uploadZone">
          <div class="upload-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          </div>
          <p class="upload-text">拖拽 Excel 文件到此处</p>
          <p class="upload-hint">或点击选择文件 &middot; 支持 .xlsx &middot; 最大 20MB</p>
          <input type="file" name="datafile" accept=".xlsx,.xls" id="fileInput" required>
        </div>
        <div class="file-info" id="fileInfo">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <span id="fileName"></span>
          <button type="button" class="file-clear" id="fileClear">&times;</button>
        </div>
        <button type="submit" class="btn btn-primary btn-lg" id="btnSubmit" disabled>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          <span>开始分析</span>
        </button>
      </form>

      <% if (!analysis) { %>
      <div class="steps">
        <div class="step">
          <div class="step-num">1</div>
          <div class="step-text">
            <strong>下载模板</strong>
            <span>获取标准 Excel 模板</span>
          </div>
        </div>
        <div class="step-arrow">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
        <div class="step">
          <div class="step-num">2</div>
          <div class="step-text">
            <strong>填写数据</strong>
            <span>录入月度运营数据</span>
          </div>
        </div>
        <div class="step-arrow">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
        <div class="step">
          <div class="step-num">3</div>
          <div class="step-text">
            <strong>上传分析</strong>
            <span>自动生成分析报告</span>
          </div>
        </div>
        <div class="step-arrow">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </div>
        <div class="step">
          <div class="step-num">4</div>
          <div class="step-text">
            <strong>导出报告</strong>
            <span>下载独立 HTML 文件</span>
          </div>
        </div>
      </div>
      <% } %>
    </section>

    <% if (analysis && typeof reportBody !== 'undefined' && reportBody) { %>
    <style>.app { max-width: 1140px; transition: max-width 0.4s ease-out; }</style>
    <section class="result-actions" style="margin-bottom: 24px; display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="/preview" target="_blank" class="btn btn-primary btn-lg" style="padding: 14px 32px">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        全屏独立预览
      </a>
      <a href="/export" class="btn btn-success btn-lg" download style="padding: 14px 32px;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        下载HTML报告
      </a>
      <button id="btnPdf" class="btn btn-lg" style="padding: 14px 32px; background: #7c3a2d; color: #fff; border: none; cursor: pointer;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 6px;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        导出PDF
      </button>
    </section>

    <div class="embedded-report-container" style="background: #f8fafc; border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); border: 1px solid #e2e8f0; margin-bottom: 40px; overflow: hidden;">
      <%- reportBody %>
    </div>
    <% } %>
  </main>

  <footer class="app-footer">
    <p>科室运营智能分析系统 v2.0</p>
  </footer>
</div>

<script>
const zone = document.getElementById('uploadZone');
const input = document.getElementById('fileInput');
const info = document.getElementById('fileInfo');
const nameEl = document.getElementById('fileName');
const btn = document.getElementById('btnSubmit');
const clear = document.getElementById('fileClear');

zone.addEventListener('click', (e) => { if (e.target !== input) input.click(); });
zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('dragover'); });
zone.addEventListener('dragleave', () => zone.classList.remove('dragover'));
zone.addEventListener('drop', e => {
  e.preventDefault();
  zone.classList.remove('dragover');
  if (e.dataTransfer.files.length) {
    input.files = e.dataTransfer.files;
    onFile();
  }
});
input.addEventListener('change', onFile);
clear.addEventListener('click', () => {
  input.value = '';
  info.classList.remove('show');
  zone.style.display = '';
  btn.disabled = true;
});

function onFile() {
  if (!input.files.length) return;
  const f = input.files[0];
  nameEl.textContent = f.name + ' (' + (f.size / 1024).toFixed(0) + ' KB)';
  info.classList.add('show');
  zone.style.display = 'none';
  btn.disabled = false;
}

document.getElementById('uploadForm')?.addEventListener('submit', function (e) {
  if (btn.dataset.submitting === '1') return;
  btn.dataset.submitting = '1';
  btn.querySelector('span').textContent = '分析中...';
  btn.classList.add('loading');
  btn.style.pointerEvents = 'none';
  btn.style.opacity = '0.7';
});

// PDF export
var pdfBtn = document.getElementById('btnPdf');
if (pdfBtn) {
  pdfBtn.addEventListener('click', function () {
    var el = document.querySelector('.embedded-report-container');
    if (!el) return alert('暂无报告内容');
    var label = pdfBtn.textContent;
    pdfBtn.textContent = '生成中…';
    pdfBtn.disabled = true;
    pdfBtn.style.opacity = '0.6';

    // Expand all <details> so content appears in PDF
    var details = el.querySelectorAll('details');
    details.forEach(function(d){ d.setAttribute('open',''); });

    var opt = {
      margin:       [8, 4, 8, 4],
      filename:     '运营分析报告.pdf',
      image:        { type: 'jpeg', quality: 0.95 },
      html2canvas:  { scale: 2, useCORS: true, scrollY: 0, windowWidth: 1100 },
      jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' },
      pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] }
    };

    html2pdf().set(opt).from(el).save().then(function(){
      pdfBtn.innerHTML = label;
      pdfBtn.disabled = false;
      pdfBtn.style.opacity = '';
    }).catch(function(err){
      console.error(err);
      pdfBtn.innerHTML = label;
      pdfBtn.disabled = false;
      pdfBtn.style.opacity = '';
      alert('PDF 导出失败: ' + err.message);
    });
  });
}
</script>
</body>
</html>
